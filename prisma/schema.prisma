generator client {
  provider        = "prisma-client-js"
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

model Inventory {
  id              String   @id @default(uuid())
  name            String
  stockLevel      Float
  safetyThreshold Float    @default(0)
  unit            String
  recipes         Recipe[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  name      String
  recipes   Recipe[]
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recipe {
  id          String    @id @default(uuid())
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  ingredient  Inventory @relation(fields: [inventoryId], references: [id])
  inventoryId String
  quantity    Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, inventoryId])
}

model Sale {
  id           String   @id @default(uuid())
  product      Product  @relation(fields: [productId], references: [id])
  productId    String
  quantitySold Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}